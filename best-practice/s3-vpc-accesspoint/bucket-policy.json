{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyIfNotFromAllowedVPC",
      "Effect": "Deny",
      "Principal": "*",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket",
        "s3:PutObject"
      ],
      "Resource": [
        "arn:aws:s3:::test-335014104427-ap-northeast-1-an",
        "arn:aws:s3:::test-335014104427-ap-northeast-1-an/*"
      ],
      "Condition": {
        "StringNotEquals": {
          "aws:SourceVpc": "vpc-00487d4a3d1990e73"
        }
      }
    }
  ]
}