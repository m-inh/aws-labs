{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowListOnlySpecificFolder",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": [
        "arn:aws:s3:ap-northeast-1:335014104427:accesspoint/vpc-endpoint",
        "arn:aws:s3:::test-335014104427-ap-northeast-1-an"
      ],
      "Condition": {
        "StringLike": {
          "s3:prefix": "test-folder/*"
        }
      }
    },
    {
      "Sid": "AllowAccessObjectsInSpecificFolder",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:ap-northeast-1:335014104427:accesspoint/vpc-endpoint/object/test-folder/*",
        "arn:aws:s3:::test-335014104427-ap-northeast-1-an/test-folder/*"
      ]
    }
  ]
}