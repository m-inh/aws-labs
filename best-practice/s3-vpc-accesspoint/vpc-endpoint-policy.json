{
  "Version": "2008-10-17",
  "Statement": [
    {
      "Sid": "AllowUseOfS3",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "s3:*",
      "Resource": "*"
    },
    {
      "Sid": "OnlyIfAccessedViaAccessPoints",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "s3:*",
      "Resource": "*",
      "Condition": {
        "ArnNotLikeIfExists": {
          "s3:DataAccessPointArn": "arn:aws:s3:ap-northeast-1:335014104427:accesspoint/*"
        }
      }
    }
  ]
}