{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowRunInstancesWithRestriction",
      "Effect": "Allow",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateTags",
        "ec2:CreateVolume"
      ],
      "Resource": [
        "arn:aws:ec2:ap-northeast-1:*:instance/*",
        "arn:aws:ec2:ap-northeast-1:*:network-interface/*",
        "arn:aws:ec2:ap-northeast-1:*:volume/*"
      ],
      "Condition": {
        "StringEquals": {
          "aws:RequestTag/Owner": "${aws:username}",
          "aws:RequestTag/Environment": ["dev", "prod"]
        },
        "StringNotLike": {
          "aws:RequestTag/Application": ""
        },
        "Null": {
          "aws:RequestTag/Application": "false"
        }
      }
    },
    {
      "Sid": "AllowRunInstancesSupplement",
      "Effect": "Allow",
      "Action": [
        "ec2:RunInstances"
      ],
      "Resource": [
        "arn:aws:ec2:ap-northeast-1:*:security-group/*",
        "arn:aws:ec2:ap-northeast-1:*:subnet/*",
        "arn:aws:ec2:ap-northeast-1:*:image/*"
      ]
    },
    {
      "Sid": "AllowDescribeAll",
      "Effect": "Allow",
      "Action": "ec2:Describe*",
      "Resource": "*"
    }
  ]
}